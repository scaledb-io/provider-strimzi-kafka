# Environment configuration for the provider dev Tiltfile (dev/Tiltfile).
#
# Copy this file to dev/.env and adjust as needed:
#   cp dev/.env.example dev/.env

# -- OpenEverest core --------------------------------------------------------

# Install the latest released OpenEverest v2 core (server + controller + CRDs)
# from the published Helm repository. Set to false if you run the core from
# source in a separate Tilt instance (see dev/README.md).
INSTALL_OPENEVEREST=true

# OpenEverest core chart version to install.
# NOTE: while OpenEverest v2 is in pre-release, the Helm repository only
# publishes pre-release tags (e.g. 2.0.0-dev.1). Helm's "latest" resolution
# skips pre-releases, so leaving this empty pulls the v1.x stable lineage
# (Percona), which has no core.openeverest.io CRDs and the provider cannot
# reconcile. Pin the v2-dev tag until v2.0.0 is generally available.
OPENEVEREST_VERSION=2.0.0-dev.1

# Helm repository that hosts the OpenEverest core chart.
OPENEVEREST_HELM_REPO=https://openeverest.github.io/helm-charts/

# Namespace the OpenEverest core is installed into.
EVEREST_NAMESPACE=everest-system

# Initial admin password for the Everest UI/API.
UI_ADMIN_PASSWORD=admin

# -- Provider ----------------------------------------------------------------

# Namespace the provider (and the database operator subchart) is deployed into.
PROVIDER_NAMESPACE=default

# Go build environment used to compile the provider binary.
PROVIDER_BUILD_ENV=CGO_ENABLED=0 GOOS=linux

# -- Cluster / registry (optional) -------------------------------------------

# Restrict Tilt to a specific Kubernetes context (recommended).
# K8S_CONTEXT=k3d-provider-strimzi-kafka-test

# Push images to a specific registry (defaults to the cluster's local registry).
# DOCKER_REGISTRY_URL=
